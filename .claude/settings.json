{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 .github/hooks/scripts/session_start.py",
        "cwd": ".",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 .github/hooks/scripts/pre_tool_use.py",
        "cwd": ".",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 .github/hooks/scripts/post_tool_use.py",
        "cwd": ".",
        "timeout": 10
      }
    ]
  }
}